# Firebase Realtime Database (IoT stepper control)
# Set these so the app can update /stepper (running + speed) when feeding starts.
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_DATABASE_URL=https://fish-feed-d65d0-default-rtdb.firebaseio.com/
FIREBASE_USER_EMAIL=your_firebase_auth_email
FIREBASE_USER_PASS=your_firebase_auth_password

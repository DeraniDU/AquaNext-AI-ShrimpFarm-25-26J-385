# Optional: Firebase Realtime Database (for live motor updates during AI processing)
# If set, the table view will push running + speed (0|1|2) to /stepper when a chunk is Confirmed.
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_DATABASE_URL=https://shrimp-feed-default-rtdb.firebaseio.com
VITE_FIREBASE_USER_EMAIL=your_firebase_email
VITE_FIREBASE_USER_PASS=your_firebase_password

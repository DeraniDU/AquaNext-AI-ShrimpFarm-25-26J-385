# Disease Detection Module Configuration
# Copy this file to .env and update with your actual credentials
# IMPORTANT: Never commit .env with real credentials to version control

# API Configuration
ENV=dev
HOST=0.0.0.0
PORT=8001

# MongoDB - Shrimp Farm Feeding Database
# Database: shrimpfeeding
# Collections: feeding_data (READ-ONLY access for feeding data)
# REQUIRED: These credentials must be set as environment variables
MONGO_URI=mongodb+srv://dbUser:Sama2001@shrimpfeeding.4tifr4r.mongodb.net/shrimpfeeding?retryWrites=true&w=majority
DB_NAME=shrimpfeeding

# Default Pond ID - Used when pond_id is not specified in requests
DEFAULT_POND_ID=1

# Model Paths (optional - defaults to models/artifacts folder)
# MODEL_DIR=/path/to/models/artifacts
# RF_MODEL_PATH=/path/to/models/artifacts/model_random_forest_multiclass.joblib
# IF_MODEL_PATH=/path/to/models/artifacts/model_isolation_forest.joblib
# SCALER_PATH=/path/to/models/artifacts/multimodal_robust_scaler.joblib

# Isolation Forest Threshold for anomaly detection
IF_THRESHOLD=-0.003891

